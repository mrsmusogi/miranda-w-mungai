---

---

<canvas id="nav-canvas" class="logo-canvas"></canvas>

<script>
  import { vs, fs } from "../assets/clown.js";

  const BACKGROUND = "#ffffff";
  const FOREGROUND = "#1f1e1e";

  const width = 200;
  const height = 200;
  const canvas = document.getElementById("nav-canvas") as HTMLCanvasElement;
  canvas.width = width;
  canvas.height = height;

  let clicked = false;
  canvas.addEventListener("mousedown", () => {
      clicked = true;
      setTimeout(toggleClicked, 2000)
  });
function toggleClicked(){
   clicked = false
}
  const ctx = canvas.getContext("2d", { willReadFrequently: true })!;
  const pixelDensity = window.devicePixelRatio || 1;

  function clear() {
    ctx.fillStyle = BACKGROUND;
    ctx.fillRect(0, 0, canvas.width, canvas.height);
  }

  function line(p1: { x: number; y: number }, p2: { x: number; y: number }) {
    ctx.lineWidth = 1;
    ctx.strokeStyle = FOREGROUND;
    ctx.beginPath();
    ctx.moveTo(p1.x, p1.y);
    ctx.lineTo(p2.x, p2.y);
    ctx.stroke();
  }

  function screen(p: { x: number; y: number }) {
    return {
      x: ((p.x + 1) / 2) * canvas.width,
      y: (1 - (p.y + 1) / 2) * canvas.height,
    };
  }

  function project({ x, y, z }: { x: number; y: number; z: number }) {
    return { x: x / z, y: y / z };
  }

  function translate_z(
    { x, y, z }: { x: number; y: number; z: number },
    dz: number,
  ) {
    return { x, y, z: z + dz };
  }

  function rotate_xz(
    { x, y, z }: { x: number; y: number; z: number },
    angle: number,
  ) {
    const c = Math.cos(angle);
    const s = Math.sin(angle);
    if (clicked) {
      return { x: x * c - y * s, y: x * s + y * c, z };
    }
    return { x: x * c - z * s, y, z: x * s + z * c };
  }

  const FPS = 30;
  let dz = 1;
  let angle = 0;

  function frame() {
    const dt = 1 / FPS;
    angle += Math.PI * dt;
    clear();

    for (const f of fs) {
      for (let i = 0; i < f.length; ++i) {
        const a = vs[f[i]];
        const b = vs[f[(i + 1) % f.length]];
        line(
          screen(project(translate_z(rotate_xz(a, angle), dz))),
          screen(project(translate_z(rotate_xz(b, angle), dz))),
        );
      }
    }
    setTimeout(frame, 1000 / FPS);
    dither();
  }

  setTimeout(frame, 1000 / FPS);

  function dither() {
    const widthPx =
      pixelDensity && !isNaN(pixelDensity)
        ? Math.floor(width * pixelDensity)
        : Math.floor(width);
    const heightPx =
      pixelDensity && !isNaN(pixelDensity)
        ? Math.floor(height * pixelDensity)
        : Math.floor(height);

    const imageData = ctx.getImageData(0, 0, widthPx, heightPx);
    const ditheredImageData = ctx.createImageData(widthPx, heightPx);

    const errorBuffer: number[][] = Array.from({ length: widthPx }, () =>
      new Array(heightPx).fill(0),
    );

    for (let d = 0; d < pixelDensity; d++) {
      for (let y = 0; y < heightPx; y++) {
        for (let x = 0; x < widthPx; x++) {
          const pixelIndex = 4 * (widthPx * y + x);
          let currentValue = imageData.data[pixelIndex] + errorBuffer[x][y];

          const newValue =
            errorBuffer[x][y] === 0
              ? 255 > currentValue
                ? 0
                : 255
              : currentValue > 128
                ? 255
                : 0;

          const error = currentValue - newValue;

          if (x < widthPx - 1) errorBuffer[x + 1][y] += (7 * error) / 20;
          if (x > 0 && y < heightPx - 1)
            errorBuffer[x - 1][y + 1] += (5 * error) / 20;
          if (y < heightPx - 1) errorBuffer[x][y + 1] += (3 * error) / 20;
          if (x < widthPx - 1 && y < heightPx - 1)
            errorBuffer[x + 1][y + 1] += (1 * error) / 20;

          ditheredImageData.data[pixelIndex] = newValue;
          ditheredImageData.data[pixelIndex + 1] = newValue;
          ditheredImageData.data[pixelIndex + 2] = newValue;
          ditheredImageData.data[pixelIndex + 3] = 255;
        }
      }
    }
    ctx.putImageData(ditheredImageData, 0, 0);
  }
</script>

<style>
  .logo-canvas {
    width: 200px;
    height: 200px;
    margin-bottom: 30px;
    border: 1px solid gray;
    border-radius: 4px;
    display: block;
    margin-left: auto;
    cursor: pointer;
  }
</style>
