<script>
  const CONTENT: Record<string, { title: string; body: string }> = {
    context: {
      title: "Context",
      body: "Placing images in new contexts that encourage expansive responses within broad themes. Offering room for images to have social value as well as artistic value.",
    },
    processes: {
      title: "Processes",
      body: "Prioritising processes — of thought, dialogue, imagining futures — above a pragmatic notion of completion. Remembering that the culmination of processes does not require a clear cut end goal. A process promises potential futures, centred on pushing the limits of what we know.",
    },
    dialogue: {
      title: "Dialogue",
      body: "Facilitating spaces that offer room to respond both to the works and to others. Finding moments of collective critical enquiry anchored in the image.",
    },
    environments: {
      title: "Environments",
      body: "I experiment, within the means afforded me, with what an exhibition space can be. I encourage personal autonomy in a space, and playful interactions with the environment.",
    },
  };

  const backdrop = document.getElementById("modal-backdrop") as HTMLElement;
  const titleEl  = document.getElementById("modal-title")   as HTMLElement;
  const bodyEl   = document.getElementById("modal-body")    as HTMLElement;

  let animationId: number | null = null;

  function animateWords(text: string) {
    bodyEl.innerHTML = "";
    if (animationId !== null) cancelAnimationFrame(animationId);

    const words = text.split(" ");
    words.forEach((word, i) => {
      const span = document.createElement("span");
      span.textContent = word + " ";
      span.className = "word";
      span.style.animationDelay = `${i * 55}ms`;
      bodyEl.appendChild(span);
    });
  }

  function openModal(key: string) {
    const content = CONTENT[key];
    if (!content) return;

    titleEl.textContent = content.title;
    animateWords(content.body);

    backdrop.setAttribute("aria-hidden", "false");
    backdrop.classList.add("visible");
    document.body.classList.add("modal-open");
  }

  function closeModal() {
    backdrop.classList.remove("visible");
    backdrop.setAttribute("aria-hidden", "true");
    document.body.classList.remove("modal-open");
  }


  document.querySelectorAll<HTMLButtonElement>(".tappable").forEach((btn) => {
    btn.addEventListener("click", (e) => {
      e.stopPropagation();
      const key = btn.dataset.key;
      if (key) openModal(key);
    });
  });


  backdrop.addEventListener("click", closeModal);
  document.querySelector(".modal-box")?.addEventListener("click", (e) => e.stopPropagation());


  document.addEventListener("keydown", (e) => {
    if (e.key === "Escape") closeModal();
  });
</script>

