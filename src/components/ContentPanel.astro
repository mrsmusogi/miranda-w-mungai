---

<main class="content-panel">
  <div id="content">
    <slot />
  </div>
</main>

<style>
  .content-panel {
    width: 1400px;
    padding: 4px;
    overflow-y: auto;
    background-color: #ecf0f1;
    display: flex;
    flex-direction: column;
  }

  .content-panel :global(h1) {
    color: #555555;
    margin-bottom: 8px;
  }

  .content-panel :global(p) {
    color: #1d2021;
    margin-bottom: 15px;
  }
  #content {
    display: flex;
    justify-content: center;
    align-items: center;
    padding-top: 10%;
    padding-left: 12%;
    padding-right: 12%;
    flex: 1;
  }

  @media (769px  <= width <= 1023px) {
    .content-panel {
      width: 100%;
      max-width: 100%;
      padding: 10px;
    }

    #content {
      flex-direction: column;
      padding-top: 20px;
      padding-left: 100px;
      padding-right: 100px;
      align-items: stretch;
    }
  }
    @media (max-width: 768px) {
    .content-panel {
      width: 100%;
      max-width: 100%;
      padding: 10px;
    }

    #content {
      flex-direction: column;
      padding-top: 20px;
      padding-left: 30px;
      padding-right: 30px;
      align-items: stretch;
    }
  }
</style>
